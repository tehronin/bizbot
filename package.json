{
  "name": "bizbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-stack.mjs dev",
    "dev:vscode": "node scripts/run-stack.mjs dev-webpack",
    "dev:web": "node ./node_modules/next/dist/bin/next dev",
    "dev:web:webpack": "node ./node_modules/next/dist/bin/next dev --webpack",
    "worker": "node scripts/run-worker.mjs",
    "mcp:stdio": "tsx scripts/mcp-stdio.mjs",
    "mcp:stdio:smoke": "tsx scripts/mcp-stdio-sampling-smoke.mjs",
    "inspect:mcp-devloop": "tsx scripts/inspect-mcp-devloop.ts",
    "plugin:new": "node scripts/new-plugin.mjs",
    "build:web": "next build && node scripts/prepare-standalone.mjs",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "cleanup:junk": "node scripts/cleanup-generated-artifacts.mjs --older-than-hours=24",
    "cleanup:junk:dry-run": "node scripts/cleanup-generated-artifacts.mjs --dry-run --older-than-hours=24",
    "cleanup:junk:all": "node scripts/cleanup-generated-artifacts.mjs --include-fresh --older-than-hours=0",
    "cleanup:junk:schedule:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-weekly-cleanup-task.ps1",
    "cleanup:junk:schedule:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/remove-weekly-cleanup-task.ps1",
    "start": "node scripts/run-stack.mjs start",
    "start:web": "node .next/standalone/server.js",
    "lint": "eslint",
    "lint:docs": "markdownlint-cli2 \"README.md\" \"CONTRIBUTING.md\" \"CHANGELOG.md\" \"docs/**/*.md\"",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:app": "node ./node_modules/vitest/vitest.mjs run --config vitest.app.config.ts --passWithNoTests",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:mcp": "node ./node_modules/vitest/vitest.mjs run tests/mcp tests/plugins",
    "test:mcp:sampling": "node ./node_modules/vitest/vitest.mjs run tests/mcp/sampling.test.ts tests/mcp/stdio-sampling-e2e.test.ts tests/mcp/server.test.ts tests/mcp/http-route.test.ts tests/mcp/stdio-env.test.ts tests/mcp/sampling-policy-resource.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:builder": "playwright test tests/e2e/builder.spec.ts",
    "verify:local": "node scripts/verify-local.mjs",
    "tauri:prepare-resources": "node scripts/prepare-tauri-resources.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@prisma/client": "^6.16.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "axios": "^1.13.6",
    "bullmq": "^5.71.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "neo4j-driver": "^6.0.1",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "playwright": "^1.58.2",
    "prisma": "^6.16.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "twitter-api-v2": "^1.29.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "markdownlint-cli2": "^0.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
