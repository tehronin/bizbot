{
  "name": "bizbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-stack.mjs dev",
    "dev:web": "next dev",
    "worker": "tsx --env-file=.env src/workers/agent-worker.ts",
    "mcp:stdio": "tsx --env-file=.env scripts/mcp-stdio.mjs",
    "plugin:new": "node scripts/new-plugin.mjs",
    "build:web": "next build",
    "build": "next build",
    "start": "node scripts/run-stack.mjs start",
    "start:web": "next start",
    "lint": "eslint",
    "lint:docs": "markdownlint-cli2",
    "test": "vitest run",
    "test:app": "vitest run --exclude tests/mcp/** --exclude tests/plugins/** --passWithNoTests",
    "test:watch": "vitest",
    "test:mcp": "vitest run tests/mcp tests/plugins",
    "tauri:prepare-resources": "node scripts/prepare-tauri-resources.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@prisma/client": "^6.16.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "axios": "^1.13.6",
    "bullmq": "^5.71.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "neo4j-driver": "^6.0.1",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "playwright": "^1.58.2",
    "prisma": "^6.16.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "twitter-api-v2": "^1.29.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "markdownlint-cli2": "^0.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
