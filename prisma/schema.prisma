// BizBot — Local Desktop Social Media Agent
// Prisma schema with pgvector support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────── USER ───────────────────
model User {
  id          String   @id @default(cuid())
  name        String   @default("User")
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
  posts         Post[]
  memories      Memory[]
  userMemoryFacts UserMemoryFact[]
  oraclePredictions OraclePrediction[]
  ontologyEntities OntologyEntity[]   @relation("UserOntologyEntities")
  ontologyRelations OntologyRelation[] @relation("UserOntologyRelations")
}

// ─────────────────── PLATFORMS ───────────────────
model Platform {
  id               String         @id @default(cuid())
  type             PlatformType
  displayName      String
  username         String?
  connected        Boolean        @default(false)
  useBrowserMode   Boolean        @default(false) // experimental opt-in
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  posts            Post[]
  analyticsSnapshots AnalyticsSnapshot[]
  inboxMessages    InboxMessage[]
}

enum PlatformType {
  TWITTER
  FACEBOOK
  INSTAGRAM
}

enum LeadStage {
  NONE
  LEAD
  QUALIFIED
  CONTACTED
  CONVERTED
  LOST
}

// ─────────────────── POSTS ───────────────────
model Post {
  id          String      @id @default(cuid())
  content     String
  mediaUrls   String[]    @default([])
  platform    Platform    @relation(fields: [platformId], references: [id])
  platformId  String
  author      User        @relation(fields: [authorId], references: [id])
  authorId    String
  status      PostStatus  @default(DRAFT)
  externalId  String?     // ID from the social platform after publishing
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  approval    PostApproval?
  analytics   AnalyticsSnapshot[]
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

// ─────────────────── APPROVALS ───────────────────
model PostApproval {
  id          String         @id @default(cuid())
  post        Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String         @unique
  status      ApprovalStatus @default(PENDING)
  decidedAt   DateTime?
  autoApproveRule String?    // name of the rule that auto-approved, if any
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

enum ChatExecutionMode {
  ASK
  AGENT
}

enum ExternalDataSourceType {
  POSTGRES
}

enum ExternalDataSourceStatus {
  PENDING
  READY
  PROFILED
  DISCONNECTED
  FAILED
  ARCHIVED
}

enum SourceScanStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum CompanyIngestionPlanStatus {
  DRAFT
  APPROVED
  SUPERSEDED
  ARCHIVED
}

enum CompanyIngestionRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
  CANCELLED
}

enum CompanyChunkKind {
  ROW
  ENTITY
  EVENT_ROLLUP
  TEXT_WINDOW
  JSON_SUMMARY
  RELATION_SUMMARY
}

enum CompanyEntityLinkType {
  EXPLICIT
  INFERRED
}

// ─────────────────── CONVERSATIONS ───────────────────
model Conversation {
  id            String    @id @default(cuid())
  title         String?
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  builderProject   BuilderProject? @relation(fields: [builderProjectId], references: [id], onDelete: Cascade)
  builderProjectId String?
  companyProfile CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  companyProfileId String?
  defaultMode   ChatExecutionMode @default(ASK)
  defaultPluginId String  @default("just-chatting")
  promptSummary String?
  promptSummaryUpdatedAt DateTime?
  archivedAt    DateTime?
  deletedAt     DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      Message[]
  builderInteractions BuilderInteraction[]

  @@index([userId, archivedAt, deletedAt, lastMessageAt])
  @@index([builderProjectId, archivedAt, deletedAt, lastMessageAt])
  @@index([companyProfileId, archivedAt, deletedAt, lastMessageAt])
}

model OraclePrediction {
  id                        String   @id @default(cuid())
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                    String
  conversationId            String?
  rawPrompt                 String
  normalizedPrompt          String
  canonicalQuestion         String
  asset                     String?
  personality               String
  isWatched                 Boolean  @default(false)
  analysisCount             Int      @default(0)
  lastEvidenceMode          String?
  lastImpliedProbability    Float?
  lastCalibratedProbability Float?
  lastConfidence            String?
  lastSentiment             String?
  lastHeadline              String?
  lastSummary               String?
  lastSummaryPacket         String?
  lastSourceBlend           Json?
  lastEvidenceGaps          Json?
  lastVerdict               Json?
  lastAnalyzedAt            DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([userId, canonicalQuestion], name: "userId_canonicalQuestion")
  @@index([userId, isWatched, updatedAt])
  @@index([userId, updatedAt])
}

model CompanyProfile {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  status          String
  ontologyConfig  Json?
  retrievalConfig Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversations   Conversation[]
  sources         CompanyProfileSource[]
  ingestionPlans  CompanyIngestionPlan[]
  knowledgeChunks CompanyKnowledgeChunk[]
  entities        CompanyEntity[]
  relations       CompanyRelation[]
  retrievalAudits CompanyRetrievalAudit[]

  @@index([status, updatedAt])
}

model ExternalDataSource {
  id                    String                   @id @default(cuid())
  type                  ExternalDataSourceType
  label                 String
  host                  String
  port                  Int
  databaseName          String
  username              String
  sslMode               String
  sslRejectUnauthorized Boolean                  @default(true)
  notes                 String?
  status                ExternalDataSourceStatus @default(PENDING)
  lastTestedAt          DateTime?
  lastProfiledAt        DateTime?
  metadata              Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  secret                ExternalDataSourceSecret?
  companyProfiles       CompanyProfileSource[]
  scans                 SourceScan[]
  ingestionPlans        CompanyIngestionPlan[]
  knowledgeChunks       CompanyKnowledgeChunk[]

  @@index([status, updatedAt])
  @@index([host, databaseName])
}

model ExternalDataSourceSecret {
  sourceId              String   @id
  encryptedPassword     String
  encryptionKeyVersion  Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  source                ExternalDataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model CompanyProfileSource {
  id               String   @id @default(cuid())
  companyProfileId String
  sourceId         String
  isPrimary        Boolean  @default(false)
  role             String
  createdAt        DateTime @default(now())

  companyProfile   CompanyProfile     @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  source           ExternalDataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([companyProfileId, sourceId])
  @@index([companyProfileId, isPrimary])
  @@index([sourceId, createdAt])
}

model SourceScan {
  id           String           @id @default(cuid())
  sourceId     String
  status       SourceScanStatus @default(QUEUED)
  startedAt    DateTime?        @default(now())
  completedAt  DateTime?
  summary      Json?
  errorText    String?
  scanConfig   Json?
  createdAt    DateTime         @default(now())

  source          ExternalDataSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  schemaProfiles  SourceSchemaProfile[]
  tableProfiles   SourceTableProfile[]

  @@index([sourceId, createdAt])
  @@index([sourceId, status, createdAt])
}

model SourceSchemaProfile {
  id         String   @id @default(cuid())
  scanId      String
  schemaName  String
  tableCount  Int
  viewCount   Int
  metadata    Json?

  scan        SourceScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@unique([scanId, schemaName])
  @@index([schemaName])
}

model SourceTableProfile {
  id                String   @id @default(cuid())
  scanId            String
  schemaName        String
  tableName         String
  tableType         String
  estimatedRowCount Int?
  exactRowCount     Int?
  primaryKey        Json?
  foreignKeys       Json?
  indexes           Json?
  sampleSummary     Json?
  classification    Json?
  ingestionScore    Float?
  metadata          Json?

  scan              SourceScan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  columns           SourceColumnProfile[]

  @@unique([scanId, schemaName, tableName])
  @@index([schemaName, tableName])
  @@index([scanId, ingestionScore])
}

model SourceColumnProfile {
  id               String   @id @default(cuid())
  tableProfileId   String
  columnName       String
  dataType         String
  isNullable       Boolean
  isArray          Boolean
  isJson           Boolean
  distinctEstimate Float?
  nullFraction     Float?
  avgWidth         Float?
  semanticTags     Json?
  sensitivity      Json?
  sampleValues     Json?
  metadata         Json?

  tableProfile     SourceTableProfile @relation(fields: [tableProfileId], references: [id], onDelete: Cascade)

  @@unique([tableProfileId, columnName])
  @@index([columnName])
}

model CompanyIngestionPlan {
  id              String                     @id @default(cuid())
  companyProfileId String
  sourceId        String
  status          CompanyIngestionPlanStatus @default(DRAFT)
  version         Int
  businessGoal    String?
  selectedTables  Json
  selectedColumns Json
  redactionPolicy Json
  chunkingPolicy  Json
  embeddingPolicy Json
  ontologyPolicy  Json
  graphPolicy     Json
  retrievalPolicy Json
  plannerNotes    Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  companyProfile  CompanyProfile        @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  source          ExternalDataSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runs            CompanyIngestionRun[]

  @@unique([companyProfileId, version])
  @@index([companyProfileId, status, updatedAt])
  @@index([sourceId, status, updatedAt])
}

model CompanyIngestionRun {
  id          String                    @id @default(cuid())
  planId      String
  status      CompanyIngestionRunStatus @default(QUEUED)
  mode        String
  stage       String
  counters    Json
  errorText   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  plan        CompanyIngestionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  knowledgeChunks CompanyKnowledgeChunk[]

  @@index([planId, createdAt])
  @@index([status, updatedAt])
  @@index([startedAt, completedAt])
}

model CompanyKnowledgeChunk {
  id              String           @id @default(cuid())
  companyProfileId String
  sourceId        String
  runId           String
  schemaName      String
  tableName       String
  sourcePrimaryKey Json?
  chunkKind       CompanyChunkKind
  title           String?
  content         String
  contentHash     String
  tokenEstimate   Int?
  metadata        Json
  createdAt       DateTime         @default(now())

  companyProfile  CompanyProfile       @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  source          ExternalDataSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  run             CompanyIngestionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  embedding       CompanyKnowledgeEmbedding?

  @@index([companyProfileId, createdAt])
  @@index([sourceId, schemaName, tableName])
  @@index([runId, createdAt])
  @@index([contentHash])
}

model CompanyKnowledgeEmbedding {
  id         String   @id @default(cuid())
  chunkId     String   @unique
  model       String
  dimensions  Int
  createdAt   DateTime @default(now())

  chunk       CompanyKnowledgeChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}

model CompanyEntity {
  id              String   @id @default(cuid())
  companyProfileId String
  canonicalName   String
  entityType      String
  sourceConfidence Float
  attributes      Json
  sourceRefs      Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  companyProfile  CompanyProfile     @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  outgoingRelations CompanyRelation[] @relation("CompanyRelationFromEntity")
  incomingRelations CompanyRelation[] @relation("CompanyRelationToEntity")

  @@index([companyProfileId, entityType, canonicalName])
  @@index([companyProfileId, updatedAt])
}

model CompanyRelation {
  id              String                @id @default(cuid())
  companyProfileId String
  fromEntityId    String
  toEntityId      String
  relationType    String
  linkType        CompanyEntityLinkType
  confidence      Float
  sourceRefs      Json
  attributes      Json?
  createdAt       DateTime              @default(now())

  companyProfile  CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  fromEntity      CompanyEntity  @relation("CompanyRelationFromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity        CompanyEntity  @relation("CompanyRelationToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([companyProfileId, relationType, createdAt])
  @@index([fromEntityId, relationType])
  @@index([toEntityId, relationType])
}

model CompanyRetrievalAudit {
  id               String   @id @default(cuid())
  companyProfileId String
  query            String
  retrievedChunkIds Json
  retrievedEntityIds Json?
  answerSummary    String?
  createdAt        DateTime @default(now())

  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)

  @@index([companyProfileId, createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           MessageRole
  content        String
  metadata       Json?        // tool calls, action cards, etc.
  createdAt      DateTime     @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

// ─────────────────── MEMORY ───────────────────
// pgvector stored via raw SQL; embedding field is unsupported at Prisma level
model Memory {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  key       String
  value     String
  category  String   @default("general") // e.g. preference, fact, topic
  // embedding vector(1536) — managed via raw SQL (pgvector unsupported in Prisma)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
}

model UserMemoryFact {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  category  String
  key       String
  value     Json
  source    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key], name: "userId_key")
  @@index([userId, category])
  @@index([userId, key])
}

model OntologyEntity {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation("UserOntologyEntities", fields: [userId], references: [id], onDelete: Cascade)
  scope       String
  type        String
  canonicalKey String
  displayName String
  description String?
  attributes  Json
  status      String
  source      String
  confidence  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjectRelations OntologyRelation[] @relation("OntologyRelationSubject")
  objectRelations  OntologyRelation[] @relation("OntologyRelationObject")
  aliases          OntologyAlias[]
  evidence         OntologyEvidence[]

  @@index([userId, scope, type, canonicalKey])
  @@index([scope, type, canonicalKey])
  @@index([status, scope])
}

model OntologyRelation {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation("UserOntologyRelations", fields: [userId], references: [id], onDelete: Cascade)
  scope           String
  type            String
  subjectEntityId String
  objectEntityId  String
  attributes      Json
  source          String
  confidence      Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subjectEntity OntologyEntity @relation("OntologyRelationSubject", fields: [subjectEntityId], references: [id], onDelete: Cascade)
  objectEntity  OntologyEntity @relation("OntologyRelationObject", fields: [objectEntityId], references: [id], onDelete: Cascade)
  evidence      OntologyEvidence[]

  @@index([userId, scope, type])
  @@index([subjectEntityId, type])
  @@index([objectEntityId, type])
  @@index([isActive, scope])
}

model OntologyAlias {
  id              String   @id @default(cuid())
  entityId        String
  scope           String
  value           String
  normalizedValue String
  kind            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entity OntologyEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([scope, normalizedValue])
  @@index([entityId, kind])
}

model OntologyEvidence {
  id             String   @id @default(cuid())
  entityId       String?
  relationId     String?
  sourceKind     String
  sourceRef      String
  approvalMarker String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entity   OntologyEntity?   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  relation OntologyRelation? @relation(fields: [relationId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([relationId])
  @@index([sourceKind, sourceRef])
}

// ─────────────────── POLICIES ───────────────────
model Policy {
  id          String     @id @default(cuid())
  name        String
  type        PolicyType
  description String?
  rules       Json       // flexible rule storage
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum PolicyType {
  GUARDRAIL        // banned words, topic restrictions
  BRAND_VOICE      // tone & persona enforcement
  BROWSER_ALLOWLIST // URL access control
  SCHEDULE         // posting schedule limits
  AUTO_APPROVE     // auto-approval conditions
}

// ─────────────────── SCHEDULE RULES ───────────────────
model ScheduleRule {
  id           String       @id @default(cuid())
  platformType PlatformType
  maxPerDay    Int          @default(5)
  timeWindows  Json         // [{start: "09:00", end: "17:00"}]
  timezone     String       @default("UTC")
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ─────────────────── ANALYTICS ───────────────────
model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  platform    Platform @relation(fields: [platformId], references: [id])
  platformId  String
  likes       Int      @default(0)
  replies     Int      @default(0)
  shares      Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  capturedAt  DateTime @default(now())
}

// ─────────────────── SETTINGS ───────────────────
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────── INBOX ───────────────────
model InboxMessage {
  id            String           @id @default(cuid())
  platform      Platform         @relation(fields: [platformId], references: [id], onDelete: Cascade)
  platformId    String
  channelType   InboxChannelType
  status        InboxStatus      @default(OPEN)
  leadStage     LeadStage        @default(NONE)
  leadScore     Int              @default(0)
  leadSummary   String?
  externalId    String
  threadId      String?
  authorName    String?
  authorHandle  String?
  content       String
  replyContent  String?
  replyPostId   String?
  metadata      Json?
  cannedResponseTree   CannedResponseTree? @relation(fields: [cannedResponseTreeId], references: [id], onDelete: SetNull)
  cannedResponseTreeId String?
  cannedResponseNodeKey String?
  receivedAt    DateTime
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([platformId, externalId])
  @@index([status, channelType, receivedAt])
  @@index([leadStage, receivedAt])
}

enum InboxChannelType {
  SOCIAL_MENTION
  DIRECT_MESSAGE
}

enum InboxStatus {
  OPEN
  PROCESSING
  DRAFTED
  REPLIED
  DISMISSED
  FAILED
}

// ─────────────────── BROWSER SESSIONS ───────────────────
model BrowserSession {
  id        String   @id @default(cuid())
  domain    String   @unique
  cookies   Json     // stored cookie jar
  storage   Json?    // localStorage snapshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────── BROWSER ACTIONS (audit log) ───────────────────
model BrowserAction {
  id           String              @id @default(cuid())
  url          String
  actionType   BrowserActionType
  description  String
  status       BrowserActionStatus @default(PENDING)
  screenshotPath String?
  result       String?
  createdAt    DateTime            @default(now())
  decidedAt    DateTime?
}

model CompetitorWatch {
  id                String              @id @default(cuid())
  name              String
  url               String
  platformHint      PlatformType?
  extractSelector   String?
  notes             String?
  active            Boolean             @default(true)
  checkEveryMinutes Int                 @default(60)
  lastCheckedAt     DateTime?
  lastChangedAt     DateTime?
  lastHash          String?
  lastSummary       String?
  lastError         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  snapshots         CompetitorSnapshot[]

  @@index([active, lastCheckedAt])
}

model CompetitorSnapshot {
  id             String           @id @default(cuid())
  watch          CompetitorWatch  @relation(fields: [watchId], references: [id], onDelete: Cascade)
  watchId        String
  changeDetected Boolean          @default(false)
  summary        String
  excerpt        String
  links          Json?
  contentHash    String
  createdAt      DateTime         @default(now())

  @@index([watchId, createdAt])
  @@unique([watchId, contentHash])
}

enum BrowserActionType {
  NAVIGATE
  SCREENSHOT
  EXTRACT
  FILL_FORM
  CLICK
  DOWNLOAD
}

enum BrowserActionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

model CannedResponseTree {
  id           String            @id @default(cuid())
  name         String
  description  String?
  active       Boolean           @default(true)
  platformHint PlatformType?
  channelType  InboxChannelType?
  rootNodeKey  String
  nodes        Json
  matchRules   Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  inboxMessages InboxMessage[]

  @@index([active, platformHint, channelType])
}

enum GoogleBusinessPostStatus {
  DRAFT
  PUBLISHED
  FAILED
}

model GoogleBusinessLocation {
  id               String                @id @default(cuid())
  accountName      String
  locationName     String                @unique
  infoLocationName String?
  title            String
  storeCode        String?
  websiteUrl       String?
  regularHours     Json?
  metadata         Json?
  syncEnabled      Boolean               @default(true)
  lastSyncAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  reviews          GoogleBusinessReview[]
  posts            GoogleBusinessPost[]
}

model GoogleBusinessReview {
  id                 String                @id @default(cuid())
  location           GoogleBusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId         String
  resourceName       String
  reviewId           String
  reviewerName       String?
  reviewerPhotoUrl   String?
  starRating         Int
  comment            String?
  reviewReply        String?
  reviewReplyUpdatedAt DateTime?
  createTime         DateTime
  updateTime         DateTime
  syncedAt           DateTime              @default(now())
  needsResponse      Boolean               @default(false)

  @@unique([locationId, reviewId])
  @@index([locationId, updateTime])
}

model GoogleBusinessPost {
  id               String                 @id @default(cuid())
  location         GoogleBusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId       String
  resourceName     String?                @unique
  summary          String
  topicType        String                 @default("STANDARD")
  actionType       String?
  callToActionUrl  String?
  searchUrl        String?
  eventData        Json?
  offerData        Json?
  status           GoogleBusinessPostStatus @default(DRAFT)
  error            String?
  publishedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([locationId, status, createdAt])
}

enum BuilderPackageManager {
  NPM
  PNPM
}

enum BuilderRunStatus {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum BuilderInteractionKind {
  MCP_POLICY_RECONCILIATION
  MCP_CONTRACT_DRIFT
  DEPENDENCY_CONTRACT_DRIFT
  FILE_TOPOLOGY_CONTRACT_DRIFT
}

enum BuilderInteractionStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
}

enum BuilderRunKind {
  BOOTSTRAP
  COMMAND
  INSTALL
  GIT_INIT
  GIT_STAGE
  GIT_UNSTAGE
  GIT_COMMIT
  GIT_BRANCH
  GIT_CHECKOUT
  GIT_MERGE
  GIT_REBASE
  GIT_CLEAN
  GIT_REMOTE
  GIT_FETCH
  GIT_PULL
  GIT_PUSH
  GIT_CLONE
  CONTAINER_EXEC
  CONTAINER_TEST
  CONTAINER_START
  CONTAINER_STOP
  CONTAINER_RESTART
  SCRIPT
  GENERATOR
  AGENTIC
  ORCHESTRATION
}

enum BuilderTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum BuilderTaskStage {
  PLANNING
  IMPLEMENTING
  TESTING
  REVIEW
  DOCUMENTING
  DONE
}

enum BuilderProjectLifecycle {
  DRAFT
  PLANNED
  ACTIVE
  BLOCKED
  COMPLETE
}

enum BuilderMilestoneStatus {
  PENDING
  ACTIVE
  BLOCKED
  COMPLETE
}

enum BuilderTaskSpecStatus {
  PENDING
  ACTIVE
  BLOCKED
  COMPLETE
}

enum BuilderTaskSpecValidator {
  BUILD
  TEST
  LINT
  TYPECHECK
  NONE
  MANUAL_REVIEW
}

model BuilderProject {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  relativePath   String                @unique
  template       String
  packageManager BuilderPackageManager @default(NPM)
  gitInitialized Boolean               @default(false)
  archivedAt     DateTime?
  lifecycle      BuilderProjectLifecycle @default(DRAFT)
  lastRunStatus  BuilderRunStatus      @default(IDLE)
  context        Json?
  latestSessionSummary String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  brief          BuilderProjectBrief?
  milestones     BuilderMilestone[]
  runs           BuilderRun[]
  interactions   BuilderInteraction[]
  mcpSnapshots   BuilderMcpSnapshot[]
  tasks          BuilderTask[]
  taskSpecs      BuilderTaskSpec[]
  conversations  Conversation[]

  @@index([template, createdAt])
  @@index([archivedAt, updatedAt])
}

model BuilderProjectBrief {
  id           String         @id @default(cuid())
  project      BuilderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String         @unique
  title        String
  summary      String
  goals        String[]       @default([])
  constraints  String[]       @default([])
  deliverables String[]       @default([])
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model BuilderMilestone {
  id          String                @id @default(cuid())
  project     BuilderProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  summary     String
  status      BuilderMilestoneStatus @default(PENDING)
  sortOrder   Int
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  taskSpecs   BuilderTaskSpec[]

  @@unique([projectId, sortOrder])
  @@index([projectId, status, sortOrder])
}

model BuilderTaskSpec {
  id                        String                   @id @default(cuid())
  project                   BuilderProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId                 String
  milestone                 BuilderMilestone         @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  milestoneId               String
  title                     String
  summary                   String
  status                    BuilderTaskSpecStatus    @default(PENDING)
  sortOrder                 Int
  completionCriteria        String[]                 @default([])
  validators                BuilderTaskSpecValidator[] @default([])
  architecturalDecisionKeys String[]                 @default([])
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  executionTasks            BuilderTask[]
  mcpSnapshots              BuilderMcpSnapshot[]
  dependencies              BuilderTaskSpecDependency[] @relation("BuilderTaskSpecDependencies")
  dependents                BuilderTaskSpecDependency[] @relation("BuilderTaskSpecDependents")

  @@unique([milestoneId, sortOrder])
  @@index([projectId, status, sortOrder])
  @@index([milestoneId, status, sortOrder])
}

model BuilderTaskSpecDependency {
  taskSpec            BuilderTaskSpec @relation("BuilderTaskSpecDependencies", fields: [taskSpecId], references: [id], onDelete: Cascade)
  taskSpecId          String
  dependsOnTaskSpec   BuilderTaskSpec @relation("BuilderTaskSpecDependents", fields: [dependsOnTaskSpecId], references: [id], onDelete: Cascade)
  dependsOnTaskSpecId String

  @@id([taskSpecId, dependsOnTaskSpecId])
  @@index([dependsOnTaskSpecId])
}

model BuilderTemplatePreset {
  id                    String                @id @default(cuid())
  key                   String                @unique
  displayName           String
  description           String
  enabled               Boolean               @default(true)
  defaultPackageManager BuilderPackageManager @default(NPM)
  metadata              Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model BuilderRun {
  id          String           @id @default(cuid())
  project     BuilderProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  task        BuilderTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskId      String?
  kind        BuilderRunKind
  title       String
  status      BuilderRunStatus @default(RUNNING)
  command     String?
  args        Json?
  stdout      String?
  stderr      String?
  summary     String?
  metadata    Json?
  startedAt   DateTime         @default(now())
  finishedAt  DateTime?

  mcpSnapshots BuilderMcpSnapshot[]
  interactions BuilderInteraction[]

  @@index([projectId, startedAt])
  @@index([taskId, startedAt])
  @@index([status, startedAt])
}

model BuilderInteraction {
  id               String                   @id @default(cuid())
  project          BuilderProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  conversation     Conversation?            @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  conversationId   String?
  run              BuilderRun?              @relation(fields: [runId], references: [id], onDelete: SetNull)
  runId            String?
  kind             BuilderInteractionKind
  status           BuilderInteractionStatus @default(PENDING)
  dedupeKey        String                   @unique
  title            String
  summary          String
  metadata         Json?
  resolutionReason String?
  resolvedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([projectId, status, createdAt])
  @@index([conversationId, status, createdAt])
  @@index([runId, status, createdAt])
}

model BuilderTask {
  id                 String            @id @default(cuid())
  project            BuilderProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          String
  taskSpec           BuilderTaskSpec?  @relation(fields: [taskSpecId], references: [id], onDelete: SetNull)
  taskSpecId         String?
  title              String
  description        String
  status             BuilderTaskStatus @default(PENDING)
  stage              BuilderTaskStage  @default(PLANNING)
  acceptanceCriteria Json?
  summary            String?
  parentTask         BuilderTask?      @relation("BuilderTaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  parentTaskId       String?
  childTasks         BuilderTask[]     @relation("BuilderTaskHierarchy")
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  runs               BuilderRun[]
  mcpSnapshots       BuilderMcpSnapshot[]

  @@index([projectId, status, updatedAt])
  @@index([projectId, stage, updatedAt])
  @@index([taskSpecId, status, updatedAt])
}

model BuilderMcpSnapshot {
  id               String         @id @default(cuid())
  project          BuilderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  run              BuilderRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId            String
  task             BuilderTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskId           String?
  taskSpec         BuilderTaskSpec? @relation(fields: [taskSpecId], references: [id], onDelete: SetNull)
  taskSpecId       String?
  snapshotSequence Int
  versionHash      String
  snapshotJson     Json
  mappingsJson     Json?
  metadata         Json?
  appliedAt        DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // snapshotEmbedding vector(1536) — reserved for future raw SQL enrichment only.

  @@unique([runId, snapshotSequence])
  @@index([projectId, appliedAt])
  @@index([runId, appliedAt])
  @@index([runId, versionHash])
  @@index([taskId, appliedAt])
  @@index([taskSpecId, appliedAt])
  @@map("mcp_snapshots")
}

model BuilderCliProfile {
  id                     String   @id @default(cuid())
  key                    String   @unique
  displayName            String
  command                String
  description            String?
  enabled                Boolean  @default(false)
  supportsNonInteractive Boolean  @default(false)
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
