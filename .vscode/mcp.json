{
  "servers": {
    "bizbot": {
      "type": "stdio",
      "command": "node",
      "args": [
        "--enable-source-maps",
        "./node_modules/tsx/dist/cli.mjs",
        "scripts/mcp-stdio.mjs"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "BIZBOT_DISABLE_QUERY_LOGS": "true"
      }
    }
  }
}
